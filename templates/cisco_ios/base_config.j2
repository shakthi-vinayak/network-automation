!
! =============================================================================
! Cisco IOS/IOS-XE Base Configuration Template
! =============================================================================
! Generated by Network Automation Platform
! Device: {{ hostname }}
! Site: {{ site }}
! Region: {{ region }}
! Environment: {{ environment }}
! =============================================================================
!

!
! --- Hostname ---
hostname {{ hostname }}
!
! --- Domain ---
ip domain-name {{ dns_domain }}
{% for domain in domain_search %}
ip domain-list {{ domain }}
{% endfor %}
!
! --- Clock / NTP ---
clock timezone {{ timezone.split(' ')[0] }} {{ timezone.split(' ')[1] }}
!
{% for ntp in ntp_servers %}
ntp server {{ ntp.ip }}{% if ntp.prefer %} prefer{% endif %}{% if ntp.key_id is defined %} key {{ ntp.key_id }}{% endif %}

{% endfor %}
ntp authenticate
!
! --- DNS ---
ip name-server {{ dns_servers | join(' ') }}
!
! --- AAA ---
aaa new-model
!
{% for server in aaa.servers %}
tacacs server TACACS-{{ loop.index }}
 address ipv4 {{ server.ip }}
 key {{ server.key }}
!
{% endfor %}
aaa group server tacacs+ TACACS-GROUP
{% for server in aaa.servers %}
 server name TACACS-{{ loop.index }}
{% endfor %}
!
aaa authentication login default {{ aaa.authentication.login }}
aaa authentication enable default {{ aaa.authentication.enable }}
aaa authorization exec default {{ aaa.authorization.exec }}
aaa authorization config-commands default {{ aaa.authorization.config_commands }}
aaa accounting exec default start-stop {{ aaa.accounting.exec }}
{% for level in aaa.accounting.commands %}
aaa accounting commands {{ level }} default start-stop group tacacs+
{% endfor %}
!
! --- SSH Hardening ---
ip ssh version {{ ssh.version }}
ip ssh time-out {{ ssh.timeout }}
ip ssh authentication-retries {{ ssh.authentication_retries }}
ip ssh maxstartups {{ ssh.max_sessions }}
{% for cipher in ssh.ciphers %}
ip ssh server algorithm encryption {{ cipher }}
{% endfor %}
{% for mac in ssh.mac_algorithms %}
ip ssh server algorithm mac {{ mac }}
{% endfor %}
{% for kex in ssh.key_exchange %}
ip ssh server algorithm kex {{ kex }}
{% endfor %}
{% for algo in ssh.host_key_algorithms %}
ip ssh server algorithm hostkey {{ algo }}
{% endfor %}
line vty 0 15
 transport input ssh
 login authentication default
 exec-timeout 10 0
!
! --- SNMPv3 ---
{% for group in snmp.groups %}
snmp-server group {{ group.name }} v3 priv read ALLVIEWS
{% for user in group.users %}
snmp-server user {{ user.name }} {{ group.name }} v3 auth {{ group.auth }} {{ user.auth_key }} priv {{ group.priv }} {{ user.priv_key }}
{% endfor %}
{% endfor %}
snmp-server contact {{ snmp.contact }}
snmp-server location {{ snmp.location }}
snmp-server source-interface {{ snmp.source_interface | default('Loopback0') }}
!
! --- Syslog ---
{% for server in syslog.servers %}
logging host {{ server.ip }} transport {{ server.protocol }} port {{ server.port }}
{% endfor %}
logging trap {{ syslog.severity | default('informational') }}
logging source-interface {{ syslog.source_interface }}
logging facility {{ syslog.facility }}
logging buffered {{ syslog.buffer_size }}
logging timestamp {{ syslog.timestamp }}
!
! --- Banner ---
banner login ^C
{{ banner.login }}^C
banner motd ^C
{{ banner.motd }}^C
!
! --- Management VRF ---
vrf definition {{ management_vrf }}
 rd 65000:1
 route-target export 65000:1
 route-target import 65000:1
 address-family ipv4
 exit-address-family
!
! --- Loopback Interfaces ---
{% for lo in loopbacks %}
interface {{ 'Loopback' ~ lo.id }}
 description {{ lo.description }}
 ip address {{ lo.ip }} {{ lo.mask }}
 no shutdown
!
{% endfor %}
!
! --- Physical Interfaces ---
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
{% if iface.description is defined %}
 description {{ iface.description }}
{% endif %}
{% if iface.ip is defined %}
 ip address {{ iface.ip.address }} {{ iface.ip.mask }}
{% endif %}
{% if iface.vlan is defined %}
 switchport access vlan {{ iface.vlan }}
{% endif %}
{% if iface.mode is defined and iface.mode == 'trunk' %}
 switchport mode trunk
{% if iface.native_vlan is defined %}
 switchport trunk native vlan {{ iface.native_vlan }}
{% endif %}
{% if iface.allowed_vlans is defined %}
 switchport trunk allowed vlan {{ iface.allowed_vlans | join(',') }}
{% endif %}
{% endif %}
{% if iface.mtu is defined %}
 mtu {{ iface.mtu }}
{% endif %}
{% if iface.lacp_group is defined %}
 channel-group {{ iface.lacp_group }} mode active
{% endif %}
{% if iface.enabled | default(true) %}
 no shutdown
{% else %}
 shutdown
{% endif %}
!
{% endfor %}
!
! --- VLANs ---
{% for vlan in vlans | default([]) %}
vlan {{ vlan.id }}
 name {{ vlan.name }}
{% if vlan.state is defined %}
 state {{ vlan.state }}
{% endif %}
!
{% endfor %}
!
! --- OSPF Configuration ---
{% if routing.ospf is defined %}
router ospf {{ routing.ospf.process_id }}
 router-id {{ routing.ospf.router_id }}
{% for area in routing.ospf.areas %}
{% for network in area.networks | default([]) %}
 network {{ network.network }} {{ network.wildcard }} area {{ area.id }}
{% endfor %}
{% endfor %}
{% for iface in routing.ospf.passive_interfaces | default([]) %}
 passive-interface {{ iface }}
{% endfor %}
{% for redist in routing.ospf.redistribute | default([]) %}
 redistribute {{ redist }}
{% endfor %}
!
{% endif %}
!
! --- BGP Configuration ---
{% if routing.bgp is defined %}
router bgp {{ routing.bgp.asn }}
 bgp router-id {{ routing.bgp.router_id }}
 bgp log-neighbor-changes
{% for neighbor in routing.bgp.neighbors | default([]) %}
 neighbor {{ neighbor.ip }} remote-as {{ neighbor.remote_as }}
{% if neighbor.description is defined %}
 neighbor {{ neighbor.ip }} description {{ neighbor.description }}
{% endif %}
{% if neighbor.update_source is defined %}
 neighbor {{ neighbor.ip }} update-source {{ neighbor.update_source }}
{% endif %}
{% if neighbor.password is defined %}
 neighbor {{ neighbor.ip }} password {{ neighbor.password }}
{% endif %}
{% if neighbor.ebgp_multihop is defined %}
 neighbor {{ neighbor.ip }} ebgp-multihop {{ neighbor.ebgp_multihop }}
{% endif %}
{% endfor %}
!
{% for network in routing.bgp.networks | default([]) %}
 network {{ network.prefix }} mask {{ network.mask }}
{% endfor %}
{% for redist in routing.bgp.redistribute | default([]) %}
 redistribute {{ redist }}
{% endfor %}
{% for agg in routing.bgp.aggregates | default([]) %}
 aggregate-address {{ agg.prefix }}{% if agg.summary_only %} summary-only{% endif %}

{% endfor %}
!
{% endif %}
!
! --- Static Routes ---
{% for route in routing.static_routes | default([]) %}
ip route {{ route.prefix }} {{ route.mask | default('255.255.255.255') }} {{ route.next_hop }}{% if route.distance is defined %} {{ route.distance }}{% endif %}{% if route.name is defined %} name {{ route.name }}{% endif %}

{% endfor %}
!
! --- ACLs ---
{% for acl_item in acl | default([]) %}
{% if acl_item.type == 'extended' %}
ip access-list extended {{ acl_item.name }}
{% for entry in acl_item.entries %}
{% if entry.remark is defined %}
 remark {{ entry.remark }}
{% else %}
 {{ entry.sequence }} {{ entry.action }} {{ entry.protocol }} {{ entry.source }} {{ entry.destination }}{% if entry.log %} log{% endif %}

{% endif %}
{% endfor %}
{% elif acl_item.type == 'standard' %}
ip access-list standard {{ acl_item.name }}
{% for entry in acl_item.entries %}
 {{ entry.sequence }} {{ entry.action }} {{ entry.source }}
{% endfor %}
{% endif %}
!
{% endfor %}
!
! --- QoS ---
{% if qos is defined and qos.enabled %}
{% for policy in qos.policy_maps %}
class-map match-any {{ policy.name }}-{{ policy.classes[0].name }}
!
policy-map {{ policy.name }}
{% for class in policy.classes %}
 class {{ policy.name }}-{{ class.name }}
{% if class.priority is defined %}
  priority {{ class.priority }}
{% endif %}
{% if class.bandwidth_percent is defined %}
  bandwidth percent {{ class.bandwidth_percent }}
{% endif %}
{% endfor %}
!
{% endfor %}
{% endif %}
!
! --- NetFlow ---
{% if netflow is defined and netflow.enabled %}
flow exporter EXPORTER-1
 destination {{ netflow.destination }}
 transport udp {{ netflow.destination_port }}
 source {{ netflow.source_interface }}
!
flow monitor MONITOR-1
 exporter EXPORTER-1
 record netflow ipv4 original-input
!
{% endif %}
!
! --- BFD ---
{% if bfd is defined and bfd.enabled %}
bfd
!
{% endif %}
!
! --- End ---
end
