---
extends: default

rules:
  line-length:
    max: 200
    level: warning
  comments:
    min-spaces-from-content: 1
  truthy: disable
  indentation:
    spaces: 2
    indent-sequences: true
  document-start:
    present: true
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1

ignore: |
  .venv/
  venv/
  .terraform/
  node_modules/
