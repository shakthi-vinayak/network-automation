# =============================================================================
# Network Automation Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Vault Configuration ---
VAULT_ADDR=https://vault.example.com:8200
VAULT_TOKEN=<your-vault-token>
VAULT_NAMESPACE=network-automation
VAULT_ROLE_ID=<your-approle-role-id>
VAULT_SECRET_ID=<your-approle-secret-id>

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_DEFAULT_REGION=us-east-1

# --- Azure Configuration ---
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_CLIENT_ID=<your-azure-client-id>
AZURE_CLIENT_SECRET=<your-azure-client-secret>

# --- GCP Configuration ---
GOOGLE_CREDENTIALS=/path/to/gcp-service-account.json
GOOGLE_PROJECT=<your-gcp-project-id>

# --- Ansible Vault ---
ANSIBLE_VAULT_PASSWORD_FILE=.vault_pass

# --- CyberArk Configuration ---
CYBERARK_URL=https://cyberark.example.com
CYBERARK_USERNAME=<your-cyberark-user>
CYBERARK_SAFE=NetworkAutomation

# --- Monitoring ---
PROMETHEUS_URL=http://prometheus.example.com:9090
GRAFANA_URL=http://grafana.example.com:3000
GRAFANA_API_KEY=<your-grafana-api-key>

# --- ChatOps ---
SLACK_BOT_TOKEN=xoxb-<your-slack-bot-token>
SLACK_SIGNING_SECRET=<your-slack-signing-secret>
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/<your-teams-webhook>

# --- Database (for state tracking) ---
DATABASE_URL=postgresql://user:password@localhost:5432/netautomation

# --- Redis (for job queues) ---
REDIS_URL=redis://localhost:6379/0

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=<generate-random-secret>
